<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Предпросмотр виджета:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:id="@+id/widget_preview_container"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/widget_border">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/preview_hour_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Четыре"
                    android:textColor="@android:color/black"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/preview_day_night_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="дня"
                    android:textColor="@android:color/holo_red_dark"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/preview_day_of_week_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Понедельник"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/preview_date_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Тринадцатое марта"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/preview_minute_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сорок три"
                    android:textColor="@android:color/black"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/preview_second_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="пять"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:visibility="gone" />

            </LinearLayout>

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Стиль виджета:"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/style_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Цвет текста:" />

        <Spinner
            android:id="@+id/color_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Размер шрифта:" />

        <SeekBar
            android:id="@+id/font_size_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="72"
            android:min="8"
            android:progress="24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Цвет рамки:" />

        <Spinner
            android:id="@+id/border_color_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Толщина рамки:" />

        <SeekBar
            android:id="@+id/border_width_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20"
            android:min="0"
            android:progress="2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Цвет фона:" />

        <Spinner
            android:id="@+id/background_color_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показывать секунды:" />

        <CheckBox
            android:id="@+id/show_seconds_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показывать секунды" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Секунды словами или цифрами:" />

        <CheckBox
            android:id="@+id/seconds_as_words_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Секунды словами" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Размер шрифта минут:" />

        <SeekBar
            android:id="@+id/minute_font_size_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="72"
            android:min="8"
            android:progress="24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Размер шрифта секунд:" />

        <SeekBar
            android:id="@+id/second_font_size_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="72"
            android:min="8"
            android:progress="18" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показывать дату:" />

        <CheckBox
            android:id="@+id/show_date_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показывать дату" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показывать день недели:" />

        <CheckBox
            android:id="@+id/show_day_of_week_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показывать день недели" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Использовать 12-часовой формат:" />

        <CheckBox
            android:id="@+id/use_12hour_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12-часовой формат" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Прозрачность фона:" />

        <SeekBar
            android:id="@+id/background_alpha_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="255"
            android:min="0"
            android:progress="0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Позиция элементов (влево/вправо сверху/снизу):"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение часа по X:" />
        <SeekBar
            android:id="@+id/hour_offset_x_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение часа по Y:" />
        <SeekBar
            android:id="@+id/hour_offset_y_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение минут по X:" />
        <SeekBar
            android:id="@+id/minute_offset_x_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение минут по Y:" />
        <SeekBar
            android:id="@+id/minute_offset_y_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение секунд по X:" />
        <SeekBar
            android:id="@+id/second_offset_x_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение секунд по Y:" />
        <SeekBar
            android:id="@+id/second_offset_y_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение даты по X:" />
        <SeekBar
            android:id="@+id/date_offset_x_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение даты по Y:" />
        <SeekBar
            android:id="@+id/date_offset_y_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение дня недели по X:" />
        <SeekBar
            android:id="@+id/day_of_week_offset_x_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение дня недели по Y:" />
        <SeekBar
            android:id="@+id/day_of_week_offset_y_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение времени суток по X:" />
        <SeekBar
            android:id="@+id/day_night_offset_x_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Смещение времени суток по Y:" />
        <SeekBar
            android:id="@+id/day_night_offset_y_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="400"
            android:progress="200" />

        <Button
            android:id="@+id/save_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сохранить" />

    </LinearLayout>
</ScrollView>